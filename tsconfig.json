{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "experimentalDecorators":  true,
                            "useDefineForClassFields":  false,
                            "module":  "ESNext",
                            "lib":  [
                                        "ES2022",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "skipLibCheck":  true,
                            "types":  [
                                          "node",
                                          "react",
                                          "react-dom"
                                      ],
                            "moduleResolution":  "bundler",
                            "isolatedModules":  true,
                            "moduleDetection":  "force",
                            "allowJs":  true,
                            "jsx":  "react-jsx",
                            "paths":  {
                                          "@/*":  [
                                                      "./*"
                                                  ]
                                      },
                            "allowImportingTsExtensions":  true,
                            "noEmit":  true
                        },
    "exclude":  [
                    "node_modules",
                    "dist",
                    "build",
                    ".git",
                    "_techsubbies_backup_*",
                    "**/_techsubbies_backup_*",
                    "**/*.backup.*",
                    "**/*.backup-*",
                    "**/*backup-before*"
                ]
}
